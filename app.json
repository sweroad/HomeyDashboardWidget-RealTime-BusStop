        {
          "id": "lines",
          "type": "text",
          "title": {
            "en": "Filter Lines (optional)",
            "sv": "Filtrera linjer (valfritt)"
          },
          "hint": {
            "en": "Comma-separated line numbers, e.g. 1,4,12. Leave empty to show all.",
            "sv": "Kommaseparerade linjenummer, t.ex. 1,4,12. Lämna tomt för alla."
