    {
      "id": "count",
      "type": "number",
      "title": { "en": "Number of Departures", "sv": "Antal avgångar" },
      "value": 5,
      "min": 1,
      "max": 10
    }
  ],
  "api": {
    "getDepartures": {
      "method": "POST",
      "path": "/"
    }
  }
