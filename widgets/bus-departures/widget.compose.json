      "hint": {
        "en": "Get a free key at trafiklab.se — add the \"Trafiklab Realtime APIs\" product.",
        "sv": "Hämta en gratis nyckel på trafiklab.se — lägg till produkten \"Trafiklab Realtime APIs\"."
      },
      "value": ""
    },
    {
      "id": "operator",
      "type": "dropdown",
      "title": {
        "en": "Operator",
        "sv": "Operatör"
      },
      "value": "jlt",
      "options": [
        { "id": "jlt", "title": { "en": "JLT – Jönköpings Länstrafik", "sv": "JLT – Jönköpings Länstrafik" } },
        { "id": "sl",  "title": { "en": "SL – Storstockholms Lokaltrafik", "sv": "SL – Storstockholms Lokaltrafik" } },
        { "id": "skane", "title": { "en": "Skånetrafiken", "sv": "Skånetrafiken" } },
        { "id": "vt",  "title": { "en": "Västtrafik", "sv": "Västtrafik" } }
      ]
    },
    {
      "id": "stop",
      "type": "autocomplete",
      "title": {
        "en": "Bus Stop",
        "sv": "Hållplats"
      },
      "placeholder": {
        "en": "Search by name…",
        "sv": "Sök hållplats…"
      }
